# PostgreSQL connection string (async, used by SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ai_content_db

# Redis connection string
REDIS_URL=redis://redis:6379/0

# Groq API key (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# LLM model name used via LangChain's ChatGroq integration
LLM_MODEL=llama-3.3-70b-versatile

# Celery broker (RabbitMQ) and result backend (Redis) 
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/0

#SMTP Email service
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_16_char_app_password (Don't include any space)
EMAIL_FROM=your_email@gmail.com

EMAIL_BATCH_SIZE=50
EMAIL_MAX_RETRIES=5